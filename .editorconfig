# EditorConfig — https://editorconfig.org
# Enforces consistent formatting across all editors and IDEs.

root = true

# ----------------------------------------------------------------
# Defaults for all files
# ----------------------------------------------------------------
[*]
charset                  = utf-8
end_of_line              = lf
indent_style             = space
indent_size              = 4
tab_width                = 4
insert_final_newline     = true
trim_trailing_whitespace = true

# ----------------------------------------------------------------
# PHP source files
# ----------------------------------------------------------------
[*.php]
indent_style = space
indent_size  = 4

# ----------------------------------------------------------------
# JavaScript / TypeScript
# ----------------------------------------------------------------
[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_style = space
indent_size  = 2

# ----------------------------------------------------------------
# CSS / SCSS / LESS
# ----------------------------------------------------------------
[*.{css,scss,less}]
indent_style = space
indent_size  = 2

# ----------------------------------------------------------------
# HTML / Blade templates
# ----------------------------------------------------------------
[*.{html,htm,blade.php}]
indent_style = space
indent_size  = 2

# ----------------------------------------------------------------
# JSON / JSONC
# ----------------------------------------------------------------
[*.{json,jsonc}]
indent_style = space
indent_size  = 2

# ----------------------------------------------------------------
# YAML / YAML-based CI configs
# ----------------------------------------------------------------
[*.{yml,yaml}]
indent_style = space
indent_size  = 2

# ----------------------------------------------------------------
# XML (composer, phpcs, phpunit configs)
# ----------------------------------------------------------------
[*.xml]
indent_style = space
indent_size  = 4

# ----------------------------------------------------------------
# Markdown documentation
# ----------------------------------------------------------------
[*.{md,mdx}]
trim_trailing_whitespace = false
indent_style             = space
indent_size              = 2

# ----------------------------------------------------------------
# Makefile — MUST use tabs
# ----------------------------------------------------------------
[Makefile]
indent_style = tab
indent_size  = 4

# ----------------------------------------------------------------
# Shell scripts
# ----------------------------------------------------------------
[*.sh]
indent_style = space
indent_size  = 2
end_of_line  = lf

# ----------------------------------------------------------------
# Docker files
# ----------------------------------------------------------------
[Dockerfile]
indent_style = space
indent_size  = 4

[docker-compose*.yml]
indent_style = space
indent_size  = 2

# ----------------------------------------------------------------
# .env files — no trailing whitespace, no final newline enforcement
# ----------------------------------------------------------------
[.env*]
trim_trailing_whitespace = true
insert_final_newline     = true

# ----------------------------------------------------------------
# Git config files
# ----------------------------------------------------------------
[.gitconfig]
indent_style = tab
