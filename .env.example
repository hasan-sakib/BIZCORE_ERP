# Application
APP_NAME="BizCore ERP"
APP_ENV=local
APP_KEY=base64:CHANGE_THIS_TO_32_CHAR_RANDOM_STRING
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=Asia/Dhaka
APP_LOCALE=en

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=bizcore_erp
DB_USERNAME=bizcore
DB_PASSWORD=secret
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_HTTP_ONLY=true

# JWT
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING
JWT_TTL=60
JWT_REFRESH_TTL=20160

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@bizcore.local
MAIL_FROM_NAME="BizCore ERP"

# File Storage
STORAGE_DRIVER=local
MAX_UPLOAD_SIZE=10240
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,docx

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900
CSRF_TOKEN_LIFETIME=3600
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# Bangladesh Integrations
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta

NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_PRIVATE_KEY=
NAGAD_MERCHANT_PUBLIC_KEY=
NAGAD_BASE_URL=http://sandbox.mynagad.com:10080

# VAT
VAT_ENABLED=true
DEFAULT_VAT_RATE=15
VAT_REGISTRATION_NUMBER=

# Logging
LOG_CHANNEL=daily
LOG_LEVEL=debug
LOG_MAX_FILES=14

# Cache
CACHE_DRIVER=redis
CACHE_TTL=3600

# Queue
QUEUE_DRIVER=redis
QUEUE_RETRY_AFTER=90
