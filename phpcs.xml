<?xml version="1.0"?>
<ruleset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         name="BizCore ERP Coding Standard"
         xsi:noNamespaceSchemaLocation="vendor/squizlabs/php_codesniffer/phpcs.xsd">

    <description>PSR-12 coding standard for BizCore ERP</description>

    <!-- ================================================================
         Files and directories to inspect
    ================================================================ -->
    <file>app</file>
    <file>tests</file>

    <!-- ================================================================
         Exclusions — generated, third-party or binary directories
    ================================================================ -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/storage/*</exclude-pattern>
    <exclude-pattern>*/bootstrap/cache/*</exclude-pattern>
    <exclude-pattern>*/public/index.php</exclude-pattern>
    <exclude-pattern>*.blade.php</exclude-pattern>
    <exclude-pattern>*_ide_helper*.php</exclude-pattern>

    <!-- ================================================================
         Base standard: PSR-12
    ================================================================ -->
    <rule ref="PSR12"/>

    <!-- ================================================================
         Additional rules beyond PSR-12
    ================================================================ -->

    <!-- Enforce short array syntax: [] over array() -->
    <rule ref="Generic.Arrays.DisallowLongArraySyntax"/>

    <!-- No trailing whitespace on blank lines inside functions -->
    <rule ref="Squiz.WhiteSpace.SuperfluousWhitespace">
        <properties>
            <property name="ignoreBlankLines" value="false"/>
        </properties>
    </rule>

    <!-- Warn on TODO / FIXME comments left in code -->
    <rule ref="Generic.Commenting.Todo"/>
    <rule ref="Generic.Commenting.Fixme"/>

    <!-- Disallow any opening PHP tag except <?php -->
    <rule ref="Generic.PHP.DisallowShortOpenTag"/>
    <rule ref="Generic.PHP.DisallowAlternativePHPTags"/>

    <!-- Require consistent cast format -->
    <rule ref="Generic.Formatting.SpaceAfterCast"/>

    <!-- One statement per line -->
    <rule ref="Generic.Formatting.DisallowMultipleStatements"/>

    <!-- Cyclomatic complexity thresholds -->
    <rule ref="Generic.Metrics.CyclomaticComplexity">
        <properties>
            <property name="complexity"     value="15"/>
            <property name="absoluteComplexity" value="25"/>
        </properties>
    </rule>

    <!-- Maximum nesting depth -->
    <rule ref="Generic.Metrics.NestingLevel">
        <properties>
            <property name="nestingLevel"         value="5"/>
            <property name="absoluteNestingLevel" value="8"/>
        </properties>
    </rule>

    <!-- ================================================================
         Rule customisations
    ================================================================ -->

    <!-- Allow longer lines in migration files (SQL can be verbose) -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit"         value="120"/>
            <property name="absoluteLineLimit" value="160"/>
        </properties>
        <exclude-pattern>*/database/*</exclude-pattern>
    </rule>

    <!-- ================================================================
         Output settings
    ================================================================ -->
    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg value="sp"/>

</ruleset>
